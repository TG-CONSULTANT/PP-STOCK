<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>P&P STOCK Management</title>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            overflow: hidden;
            background-color: #f8f9fa;
        }
        /* ปรับให้ Iframe เต็มหน้าจอและไม่มีขอบ */
        iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
    </style>
</head>
<body>

    <iframe 
        src="https://script.google.com/macros/s/AKfycbwAAq8IRRtyZMphmFo2rvdvyS7VkggyaLDDJ82khuq4U-3zR8NqIXx5lZdwK7ZMiqV3/exec" 
        allow="geolocation; microphone; camera; midi; vr; accelerometer; gyroscope; payment; ambient-light-sensor; encrypted-media; usb" 
        sandbox="allow-forms allow-scripts allow-same-origin allow-popups allow-modals">
    </iframe>

</body>
</html>
